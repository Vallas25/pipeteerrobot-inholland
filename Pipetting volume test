from opentrons import protocol_api

# metadata
metadata = {
	"apiLevel": "2.22",
    "protocolName": "vollume test",
	"description": """This protocol tests the pipetting volumes of the OT-2.""",
       "author": "Maurits Jansens"
}

# requirements
requirements = {"robotType": "OT-2"}

def run(protocol: protocol_api.ProtocolContext):
	# Labware
	tips = protocol.load_labware("opentrons_96_tiprack_300ul", "10")
	tubes = protocol.load_labware("opentrons_6_tuberack_falcon_50ml_conical", "11")
	plate = protocol.load_labware("nest_96_wellplate_200ul_flat", "9")
	# using OT-2, no trash nessicary
	right_pipette = protocol.load_instrument("p300_single", "right", tip_racks=[tips])

	# liquids
	dH2O = protocol.define_liquid(
		name = "demi water",
		description = "demi water for dilution",
		display_color= "#4bbae3",)

	tubes.load_liquid(
		wells = ["A1"],
		volume = 10000,
		liquid = dH2O)

	demi = tubes["A1"]

	for i in range(8):
		row = plate.rows()[i]
		right_pipette.transfer([300, 276, 251, 227, 202, 178, 153, 129, 104, 80, 55, 30], demi, row[:],
			touch_tip = True,
			blow_out = True, blowout_destination = "destination well")
